<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE Category SYSTEM "asterix.dtd">

<Category id="48" name="Monoradar Target Reports" ver="1.30">

    <DataItem id="010">
        <DataItemName>Data Source Identifier</DataItemName>
        <DataItemDefinition>Identification of the radar station from which the data are received.</DataItemDefinition>
        <DataItemFormat desc="Two-octets fixed length data item.">
            <Fixed length="2">
                <Bits from="16" to="9">
                    <BitsShortName>SAC</BitsShortName>
                    <BitsName>System Area Code</BitsName>
                </Bits>
                <Bits from="8" to="1">
                    <BitsShortName>SIC</BitsShortName>
                    <BitsName>System Identification Code</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="020">
        <DataItemName>Target Report Descriptor</DataItemName>
        <DataItemDefinition>Type and characteristics of the target report.</DataItemDefinition>
        <DataItemFormat desc="Variable length Data Item comprising a first part of one octet, followed by one-octet extents as necessary.">
            <Variable>
                <Fixed length="1">
                    <Bits from="8" to="6">
                        <BitsShortName>TYP</BitsShortName>
                        <BitsName>Target Report Type</BitsName>
                        <BitsValue val="0">No detection</BitsValue>
                        <BitsValue val="1">Single PSR detection</BitsValue>
                        <BitsValue val="2">Single SSR detection</BitsValue>
                        <BitsValue val="3">SSR + PSR detection</BitsValue>
                        <BitsValue val="4">Single ModeS All-Call</BitsValue>
                        <BitsValue val="5">Single ModeS Roll-Call</BitsValue>
                        <BitsValue val="6">ModeS All-Call + PSR</BitsValue>
                        <BitsValue val="7">ModeS Roll-Call + PSR</BitsValue>
                    </Bits>
                    <Bits bit="5">
                        <BitsShortName>SIM</BitsShortName>
                        <BitsName>Simulated / Actual Target Report</BitsName>
                        <BitsValue val="0">Actual target report</BitsValue>
                        <BitsValue val="1">Simulated target report</BitsValue>
                    </Bits>
                    <Bits bit="4">
                        <BitsShortName>RDP</BitsShortName>
                        <BitsName>Radar Data Processing Chain Indication</BitsName>
                        <BitsValue val="0">Report from RDP Chain 1</BitsValue>
                        <BitsValue val="1">Report from RDP Chain 2</BitsValue>
                    </Bits>
                    <Bits bit="3">
                        <BitsShortName>SPI</BitsShortName>
                        <BitsName>Special Position Identification</BitsName>
                        <BitsValue val="0">Absence of SPI</BitsValue>
                        <BitsValue val="1">Special Position Identification</BitsValue>
                    </Bits>
                    <Bits bit="2">
                        <BitsShortName>RAB</BitsShortName>
                        <BitsName>Report Type (Transponder vs Field Monitor)</BitsName>
                        <BitsValue val="0">Report from aircraft transponder</BitsValue>
                        <BitsValue val="1">Report from field monitor (fixed transponder)</BitsValue>
                    </Bits>
                    <Bits bit="1" fx="1">
                        <BitsShortName>FX</BitsShortName>
                        <BitsName>Field Extension Indicator</BitsName>
                        <BitsValue val="0">End of Data Item</BitsValue>
                        <BitsValue val="1">Extension into first extent</BitsValue>
                    </Bits>
                </Fixed>
                <Fixed length="1">
                    <Bits bit="8">
                        <BitsShortName>TST</BitsShortName>
                        <BitsName>Test Target Indicator</BitsName>
                        <BitsValue val="0">Real target report</BitsValue>
                        <BitsValue val="1">Test target report</BitsValue>
                    </Bits>
                    <Bits bit="7">
                        <BitsShortName>ERR</BitsShortName>
                        <BitsName>Extended Range Indicator</BitsName>
                        <BitsValue val="0">No Extended Range</BitsValue>
                        <BitsValue val="1">Extended Range present</BitsValue>
                    </Bits>
                    <Bits bit="6">
                        <BitsShortName>XPP</BitsShortName>
                        <BitsName>X-Pulse Present Indicator</BitsName>
                        <BitsValue val="0">No X-Pulse present</BitsValue>
                        <BitsValue val="1">X-Pulse present</BitsValue>
                    </Bits>
                    <Bits bit="5">
                        <BitsShortName>ME</BitsShortName>
                        <BitsName>Military Emergency Indicator</BitsName>
                        <BitsValue val="0">No military emergency</BitsValue>
                        <BitsValue val="1">Military emergency</BitsValue>
                    </Bits>
                    <Bits bit="4">
                        <BitsShortName>MI</BitsShortName>
                        <BitsName>Military Identification Indicator</BitsName>
                        <BitsValue val="0">No military identification</BitsValue>
                        <BitsValue val="1">Military identification</BitsValue>
                    </Bits>
                    <Bits from="3" to="2">
                        <BitsShortName>FOEFRI</BitsShortName>
                        <BitsName>Identification Friend or Foe / Friendly Target</BitsName>
                        <BitsValue val="0">No Mode 4 interrogation</BitsValue>
                        <BitsValue val="1">Friendly target</BitsValue>
                        <BitsValue val="2">Unknown target</BitsValue>
                        <BitsValue val="3">No reply</BitsValue>
                    </Bits>
                    <Bits bit="1" fx="1">
                        <BitsShortName>FX</BitsShortName>
                        <BitsName>Field Extension Indicator</BitsName>
                        <BitsValue val="0">End of Data Item</BitsValue>
                        <BitsValue val="1">Extension into next extent</BitsValue>
                    </Bits>
                </Fixed>
            </Variable>
        </DataItemFormat>
    </DataItem>

    <DataItem id="030">
        <DataItemName>Warning/Error Conditions and Target Classification</DataItemName>
        <DataItemDefinition>Warning/error conditions detected by a radar station or target classification info.</DataItemDefinition>
        <DataItemFormat desc="Variable length Data Item comprising a first part of one octet, followed by one-octet extents as necessary.">
            <Variable>
                <Fixed length="1">
                    <Bits from="8" to="2">
                        <BitsShortName>Code</BitsShortName>
                        <BitsName>Warning/Error Condition Value</BitsName>
                        <BitsValue val="0">No warning/error, unknown classification</BitsValue>
                        <BitsValue val="1">Multipath Reply (Reflection)</BitsValue>
                        <BitsValue val="2">Reply due to sidelobe interrogation/reception</BitsValue>
                        <BitsValue val="3">Split plot</BitsValue>
                        <BitsValue val="4">Second time around reply</BitsValue>
                        <BitsValue val="5">Angel</BitsValue>
                        <BitsValue val="6">Slow moving target correlated with road infrastructure</BitsValue>
                        <BitsValue val="7">Fixed PSR plot</BitsValue>
                        <BitsValue val="8">Slow PSR target</BitsValue>
                        <BitsValue val="9">Low quality PSR plot</BitsValue>
                        <BitsValue val="10">Phantom SSR plot</BitsValue>
                        <BitsValue val="11">Non-Matching Mode-3/A Code</BitsValue>
                        <BitsValue val="12">Mode C / Mode S altitude code abnormal value</BitsValue>
                        <BitsValue val="13">Target in Clutter Area</BitsValue>
                        <BitsValue val="14">Maximum Doppler Response in Zero Filter</BitsValue>
                        <BitsValue val="15">Transponder anomaly detected</BitsValue>
                        <BitsValue val="16">Duplicated or Illegal Mode S Aircraft Address</BitsValue>
                        <BitsValue val="17">Mode S error correction applied</BitsValue>
                        <BitsValue val="18">Undecodable Mode C code / Mode S altitude code</BitsValue>
                        <BitsValue val="19">Birds</BitsValue>
                        <BitsValue val="20">Flock of Birds</BitsValue>
                        <BitsValue val="21">Mode-1 was present in original reply</BitsValue>
                        <BitsValue val="22">Mode-2 was present in original reply</BitsValue>
                        <BitsValue val="23">Plot potentially caused by Wind Turbine</BitsValue>
                        <BitsValue val="24">Helicopter</BitsValue>
                        <BitsValue val="25">Maximum number of re-interrogations reached (Surveillance)</BitsValue>
                        <BitsValue val="26">Maximum number of re-interrogations reached (BDS)</BitsValue>
                        <BitsValue val="27">BDS Overlay Incoherence</BitsValue>
                        <BitsValue val="28">Potential BDS Swap Detected</BitsValue>
                        <BitsValue val="29">Track Update in the Zenithal Gap</BitsValue>
                        <BitsValue val="30">Mode S Track re-acquired</BitsValue>
                        <BitsValue val="31">Duplicated Mode 5 Pair NO/PIN detected</BitsValue>
                        <BitsValue val="32">Wrong DF reply format detected</BitsValue>
                        <BitsValue val="33">Transponder anomaly (DF replies with Mode A/C to All-Call)</BitsValue>
                        <BitsValue val="34">Transponder anomaly (SI capability report wrong)</BitsValue>
                    </Bits>
                    <Bits bit="1" fx="1">
                        <BitsShortName>FX</BitsShortName>
                        <BitsName>Field Extension Indicator</BitsName>
                        <BitsValue val="0">End of Data Item</BitsValue>
                        <BitsValue val="1">Extension into next extent</BitsValue>
                    </Bits>
                </Fixed>
            </Variable>
        </DataItemFormat>
    </DataItem>

    <DataItem id="040">
        <DataItemName>Measured Position in Polar Co-ordinates</DataItemName>
        <DataItemDefinition>Measured position of an aircraft in local slant polar coordinates.</DataItemDefinition>
        <DataItemFormat desc="Four-octet fixed length Data Item.">
            <Fixed length="4">
                <Bits from="32" to="17">
                    <BitsShortName>RHO</BitsShortName>
                    <BitsName>Slant Range</BitsName>
                    <BitsUnit scale="0.00390625">NM</BitsUnit> </Bits>
                <Bits from="16" to="1">
                    <BitsShortName>THETA</BitsShortName>
                    <BitsName>Azimuth Angle</BitsName>
                    <BitsUnit scale="0.0054931640625">deg</BitsUnit> </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="042">
        <DataItemName>Calculated Position in Cartesian Co-ordinates</DataItemName>
        <DataItemDefinition>Calculated position of an aircraft in Cartesian coordinates (Two's Complement).</DataItemDefinition>
        <DataItemFormat desc="Four-octet fixed length Data Item.">
            <Fixed length="4">
                <Bits from="32" to="17" encode="signed">
                    <BitsShortName>X</BitsShortName>
                    <BitsName>X Component</BitsName>
                    <BitsUnit scale="0.0078125">NM</BitsUnit> </Bits>
                <Bits from="16" to="1" encode="signed">
                    <BitsShortName>Y</BitsShortName>
                    <BitsName>Y Component</BitsName>
                    <BitsUnit scale="0.0078125">NM</BitsUnit> </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="050">
        <DataItemName>Mode-2 Code in Octal Representation</DataItemName>
        <DataItemDefinition>Reply to Mode-2 interrogation.</DataItemDefinition>
        <DataItemFormat desc="Two-octet fixed length Data Item.">
            <Fixed length="2">
                <Bits bit="16">
                    <BitsShortName>V</BitsShortName>
                    <BitsName>Code Validation Bit</BitsName>
                    <BitsValue val="0">Code validated</BitsValue>
                    <BitsValue val="1">Code not validated</BitsValue>
                </Bits>
                <Bits bit="15">
                    <BitsShortName>G</BitsShortName>
                    <BitsName>Garble Bit</BitsName>
                    <BitsValue val="0">Default</BitsValue>
                    <BitsValue val="1">Garbled code</BitsValue>
                </Bits>
                <Bits bit="14">
                    <BitsShortName>L</BitsShortName>
                    <BitsName>Local Tracker Smoothing Bit</BitsName>
                    <BitsValue val="0">Mode-2 transponder direct reply</BitsValue>
                    <BitsValue val="1">Smoothed Mode-2 code from local tracker</BitsValue>
                </Bits>
                <Bits bit="13">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="12" to="1" encode="octal">
                    <BitsShortName>Mode2</BitsShortName>
                    <BitsName>Mode-2 Reply Code</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="055">
        <DataItemName>Mode-1 Code in Octal Representation</DataItemName>
        <DataItemDefinition>Reply to Mode-1 interrogation.</DataItemDefinition>
        <DataItemFormat desc="One-octet fixed length data item.">
            <Fixed length="1">
                <Bits bit="8">
                    <BitsShortName>V</BitsShortName>
                    <BitsValue val="0">Code validated</BitsValue>
                    <BitsValue val="1">Code not validated</BitsValue>
                </Bits>
                <Bits bit="7">
                    <BitsShortName>G</BitsShortName>
                    <BitsValue val="0">Default</BitsValue>
                    <BitsValue val="1">Garbled Code</BitsValue>
                </Bits>
                <Bits bit="6">
                    <BitsShortName>L</BitsShortName>
                    <BitsValue val="0">Mode-1 transponder direct reply</BitsValue>
                    <BitsValue val="1">Smoothed Mode-1 code from local tracker</BitsValue>
                </Bits>
                <Bits from="5" to="1" encode="octal">
                    <BitsShortName>Mode1</BitsShortName>
                    <BitsName>Mode-1 Reply Code</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="060">
        <DataItemName>Mode-2 Code Confidence Indicator</DataItemName>
        <DataItemDefinition>Confidence level for each bit of a Mode-2 reply.</DataItemDefinition>
        <DataItemFormat desc="Two-octet fixed length Data Item.">
            <Fixed length="2">
                <Bits from="16" to="13">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="12" to="1">
                    <BitsShortName>QA_QD</BitsShortName>
                    <BitsName>Pulse Quality bits (QA4-QD1)</BitsName>
                    </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="065">
        <DataItemName>Mode-1 Code Confidence Indicator</DataItemName>
        <DataItemDefinition>Confidence level for each bit of a Mode-1 reply.</DataItemDefinition>
        <DataItemFormat desc="One-octet fixed length Data Item.">
            <Fixed length="1">
                <Bits from="8" to="6">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="5" to="1">
                    <BitsShortName>QA_QB</BitsShortName>
                    <BitsName>Pulse Quality bits (QA4-QB1)</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="070">
        <DataItemName>Mode-3/A Code in Octal Representation</DataItemName>
        <DataItemDefinition>Mode-3/A code converted into octal representation.</DataItemDefinition>
        <DataItemFormat desc="Two-octet fixed length Data Item.">
            <Fixed length="2">
                <Bits bit="16">
                    <BitsShortName>V</BitsShortName>
                    <BitsName>Validation Bit</BitsName>
                    <BitsValue val="0">Code validated</BitsValue>
                    <BitsValue val="1">Code not validated</BitsValue>
                </Bits>
                <Bits bit="15">
                    <BitsShortName>G</BitsShortName>
                    <BitsName>Garble Bit</BitsName>
                    <BitsValue val="0">Default</BitsValue>
                    <BitsValue val="1">Garbled code / Error correction applied</BitsValue>
                </Bits>
                <Bits bit="14">
                    <BitsShortName>L</BitsShortName>
                    <BitsName>Smoothing Bit</BitsName>
                    <BitsValue val="0">Mode-3/A code derived from transponder</BitsValue>
                    <BitsValue val="1">Mode-3/A code not extracted during last scan</BitsValue>
                </Bits>
                <Bits bit="13">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="12" to="1" encode="octal">
                    <BitsShortName>Mode3A</BitsShortName>
                    <BitsName>Mode-3/A Reply Code (Squawk)</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="080">
        <DataItemName>Mode-3/A Code Confidence Indicator</DataItemName>
        <DataItemDefinition>Confidence level for each bit of a Mode-3/A reply.</DataItemDefinition>
        <DataItemFormat desc="Two-octet fixed length Data Item.">
            <Fixed length="2">
                <Bits from="16" to="13">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="12" to="1">
                    <BitsShortName>Q_BITS</BitsShortName>
                    <BitsName>Quality bits for pulses A4 to D1</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="090">
        <DataItemName>Flight Level in Binary Representation</DataItemName>
        <DataItemDefinition>Flight Level converted into binary representation (Signed Type).</DataItemDefinition>
        <DataItemFormat desc="Two-octet fixed length Data Item.">
            <Fixed length="2">
                <Bits bit="16">
                    <BitsShortName>V</BitsShortName>
                    <BitsName>Validation Bit</BitsName>
                    <BitsValue val="0">Code validated</BitsValue>
                    <BitsValue val="1">Code not validated</BitsValue>
                </Bits>
                <Bits bit="15">
                    <BitsShortName>G</BitsShortName>
                    <BitsName>Garble Bit</BitsName>
                    <BitsValue val="0">Default</BitsValue>
                    <BitsValue val="1">Garbled code</BitsValue>
                </Bits>
                <Bits from="14" to="1" encode="signed">
                    <BitsShortName>FL</BitsShortName>
                    <BitsName>Flight Level</BitsName>
                    <BitsUnit scale="0.25">FL</BitsUnit> </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="100">
        <DataItemName>Mode-C Code and Confidence Indicator</DataItemName>
        <DataItemDefinition>Mode-C height in Gray notation and confidence level bits.</DataItemDefinition>
        <DataItemFormat desc="Four-octet fixed length Data Item.">
            <Fixed length="4">
                <Bits bit="32">
                    <BitsShortName>V</BitsShortName>
                    <BitsValue val="0">Code validated</BitsValue>
                    <BitsValue val="1">Code not validated</BitsValue>
                </Bits>
                <Bits bit="31">
                    <BitsShortName>G</BitsShortName>
                    <BitsValue val="0">Default</BitsValue>
                    <BitsValue val="1">Garbled code</BitsValue>
                </Bits>
                <Bits from="30" to="29">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="28" to="17">
                    <BitsShortName>ModeC</BitsShortName>
                    <BitsName>Mode-C Gray Code Representation</BitsName>
                </Bits>
                <Bits from="16" to="13">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="12" to="1">
                    <BitsShortName>QC_QD</BitsShortName>
                    <BitsName>Quality bits for Gray Code pulses</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="110">
        <DataItemName>Height Measured by a 3D Radar</DataItemName>
        <DataItemDefinition>Height measured by a 3D radar referenced to MSL (Two's Complement).</DataItemDefinition>
        <DataItemFormat desc="Two-octet fixed length Data Item.">
            <Fixed length="2">
                <Bits from="16" to="15">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="14" to="1" encode="signed">
                    <BitsShortName>Height3D</BitsShortName>
                    <BitsName>3D Height</BitsName>
                    <BitsUnit scale="25">ft</BitsUnit> </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="120">
        <DataItemName>Radial Doppler Speed</DataItemName>
        <DataItemDefinition>Information on the Doppler Speed of the target report.</DataItemDefinition>
        <DataItemFormat desc="Compound Data Item comprising primary subfield followed by subfields.">
            <Compound>
                <Variable>
                    <Fixed length="1">
                        <Bits bit="8">
                            <BitsShortName>CAL</BitsShortName>
                            <BitsName>Calculated Doppler Speed Presence</BitsName>
                            <BitsPresence>1</BitsPresence>
                        </Bits>
                        <Bits bit="7">
                            <BitsShortName>RDS</BitsShortName>
                            <BitsName>Raw Doppler Speed Presence</BitsName>
                            <BitsPresence>2</BitsPresence>
                        </Bits>
                        <Bits from="6" to="2">
                            <BitsShortName>spare</BitsShortName>
                            <BitsConst>0</BitsConst>
                        </Bits>
                        <Bits bit="1" fx="1">
                            <BitsShortName>FX</BitsShortName>
                            <BitsName>Extension Bit</BitsName>
                        </Bits>
                    </Fixed>
                </Variable>
                <Fixed length="2">
                    <Bits bit="16">
                        <BitsShortName>D</BitsShortName>
                        <BitsValue val="0">Doppler speed is valid</BitsValue>
                        <BitsValue val="1">Doppler speed is doubtful</BitsValue>
                    </Bits>
                    <Bits from="15" to="11">
                        <BitsShortName>spare</BitsShortName>
                        <BitsConst>0</BitsConst>
                    </Bits>
                    <Bits from="10" to="1" encode="signed">
                        <BitsShortName>CAL_VAL</BitsShortName>
                        <BitsUnit scale="1">m/sec</BitsUnit>
                    </Bits>
                </Fixed>
                <Repetitive>
                    <Fixed length="6">
                        <Bits from="48" to="33">
                            <BitsShortName>DOP</BitsShortName>
                            <BitsUnit scale="1">m/sec</BitsUnit>
                        </Bits>
                        <Bits from="32" to="17">
                            <BitsShortName>AMB</BitsShortName>
                            <BitsUnit scale="1">m/sec</BitsUnit>
                        </Bits>
                        <Bits from="16" to="1">
                            <BitsShortName>FRQ</BitsShortName>
                            <BitsUnit scale="1">MHz</BitsUnit>
                        </Bits>
                    </Fixed>
                </Repetitive>
            </Compound>
        </DataItemFormat>
    </DataItem>

    <DataItem id="130">
        <DataItemName>Radar Plot Characteristics</DataItemName>
        <DataItemDefinition>Additional information on the quality of the target report.</DataItemDefinition>
        <DataItemFormat desc="Compound Data Item.">
            <Compound>
                <Variable>
                    <Fixed length="1">
                        <Bits bit="8"><BitsShortName>SRL</BitsShortName><BitsPresence>1</BitsPresence></Bits>
                        <Bits bit="7"><BitsShortName>SRR</BitsShortName><BitsPresence>2</BitsPresence></Bits>
                        <Bits bit="6"><BitsShortName>SAM</BitsShortName><BitsPresence>3</BitsPresence></Bits>
                        <Bits bit="5"><BitsShortName>PRL</BitsShortName><BitsPresence>4</BitsPresence></Bits>
                        <Bits bit="4"><BitsShortName>PAM</BitsShortName><BitsPresence>5</BitsPresence></Bits>
                        <Bits bit="3"><BitsShortName>RPD</BitsShortName><BitsPresence>6</BitsPresence></Bits>
                        <Bits bit="2"><BitsShortName>APD</BitsShortName><BitsPresence>7</BitsPresence></Bits>
                        <Bits bit="1" fx="1"><BitsShortName>FX</BitsShortName></Bits>
                    </Fixed>
                </Variable>
                <Fixed length="1"><Bits from="8" to="1"><BitsShortName>SRL_VAL</BitsShortName><BitsUnit scale="0.0439453125">deg</BitsUnit></Bits></Fixed>
                <Fixed length="1"><Bits from="8" to="1"><BitsShortName>SRR_VAL</BitsShortName><BitsUnit scale="1"/></Bits></Fixed>
                <Fixed length="1"><Bits from="8" to="1" encode="signed"><BitsShortName>SAM_VAL</BitsShortName><BitsUnit scale="1">dBm</BitsUnit></Bits></Fixed>
                <Fixed length="1"><Bits from="8" to="1"><BitsShortName>PRL_VAL</BitsShortName><BitsUnit scale="0.0439453125">deg</BitsUnit></Bits></Fixed>
                <Fixed length="1"><Bits from="8" to="1" encode="signed"><BitsShortName>PAM_VAL</BitsShortName><BitsUnit scale="1">dBm</BitsUnit></Bits></Fixed>
                <Fixed length="1"><Bits from="8" to="1" encode="signed"><BitsShortName>RPD_VAL</BitsShortName><BitsUnit scale="0.00390625">NM</BitsUnit></Bits></Fixed>
                <Fixed length="1"><Bits from="8" to="1" encode="signed"><BitsShortName>APD_VAL</BitsShortName><BitsUnit scale="0.02197265625">deg</BitsUnit></Bits></Fixed>
            </Compound>
        </DataItemFormat>
    </DataItem>

    <DataItem id="140">
        <DataItemName>Time of Day</DataItemName>
        <DataItemDefinition>Absolute time stamping expressed as Co-ordinated Universal Time (UTC).</DataItemDefinition>
        <DataItemFormat>
            <Fixed length="3">
                <Bits from="24" to="1">
                    <BitsShortName>ToD</BitsShortName>
                    <BitsName>Time of Day since midnight</BitsName>
                    <BitsUnit scale="0.0078125">s</BitsUnit> </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="161">
        <DataItemName>Track/Plot Number</DataItemName>
        <DataItemDefinition>An integer value representing a unique reference to a track record.</DataItemDefinition>
        <DataItemFormat desc="Two-octet fixed length Data Item.">
            <Fixed length="2">
                <Bits from="16" to="13">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits from="12" to="1">
                    <BitsShortName>Tn</BitsShortName>
                    <BitsName>Track Number (0..4095)</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="170">
        <DataItemName>Track Status</DataItemName>
        <DataItemDefinition>Status of monoradar track (PSR and/or SSR updated).</DataItemDefinition>
        <DataItemFormat desc="Variable length Data Item comprising a first part of one octet, followed by one-octet extents as necessary.">
            <Variable>
                <Fixed length="1">
                    <Bits bit="8">
                        <BitsShortName>CNF</BitsShortName>
                        <BitsValue val="0">Confirmed Track</BitsValue>
                        <BitsValue val="1">Tentative Track</BitsValue>
                    </Bits>
                    <Bits from="7" to="6">
                        <BitsShortName>RAD</BitsShortName>
                        <BitsValue val="0">Combined Track</BitsValue>
                        <BitsValue val="1">PSR Track</BitsValue>
                        <BitsValue val="2">SSR/ModeS Track</BitsValue>
                        <BitsValue val="3">Invalid</BitsValue>
                    </Bits>
                    <Bits bit="5">
                        <BitsShortName>DOU</BitsShortName>
                        <BitsValue val="0">Normal confidence</BitsValue>
                        <BitsValue val="1">Low confidence in plot to track association</BitsValue>
                    </Bits>
                    <Bits bit="4">
                        <BitsShortName>MAH</BitsShortName>
                        <BitsValue val="0">No horizontal manoeuvre sensed</BitsValue>
                        <BitsValue val="1">Horizontal manoeuvre sensed</BitsValue>
                    </Bits>
                    <Bits from="3" to="2">
                        <BitsShortName>CDM</BitsShortName>
                        <BitsValue val="0">Maintaining</BitsValue>
                        <BitsValue val="1">Climbing</BitsValue>
                        <BitsValue val="2">Descending</BitsValue>
                        <BitsValue val="3">Unknown</BitsValue>
                    </Bits>
                    <Bits bit="1" fx="1">
                        <BitsShortName>FX</BitsShortName>
                        <BitsValue val="0">End of Data Item</BitsValue>
                        <BitsValue val="1">Extension into first extent</BitsValue>
                    </Bits>
                </Fixed>
                <Fixed length="1">
                    <Bits bit="8">
                        <BitsShortName>TRE</BitsShortName>
                        <BitsValue val="0">Track still alive</BitsValue>
                        <BitsValue val="1">End of track lifetime (last report)</BitsValue>
                    </Bits>
                    <Bits bit="7">
                        <BitsShortName>GHO</BitsShortName>
                        <BitsValue val="0">True target track</BitsValue>
                        <BitsValue val="1">Ghost target track</BitsValue>
                    </Bits>
                    <Bits bit="6">
                        <BitsShortName>SUP</BitsShortName>
                        <BitsValue val="0">No cluster network information</BitsValue>
                        <BitsValue val="1">Track maintained with neighbouring Node B data</BitsValue>
                    </Bits>
                    <Bits bit="5">
                        <BitsShortName>TCC</BitsShortName>
                        <BitsValue val="0">Tracking in Radar Plane (No Slant Correction)</BitsValue>
                        <BitsValue val="1">Tracking in 2D tangential reference plane</BitsValue>
                    </Bits>
                    <Bits from="4" to="2">
                        <BitsShortName>spare</BitsShortName>
                        <BitsConst>0</BitsConst>
                    </Bits>
                    <Bits bit="1" fx="1">
                        <BitsShortName>FX</BitsShortName>
                        <BitsValue val="0">End of Data Item</BitsValue>
                        <BitsValue val="1">Extension into next extent</BitsValue>
                    </Bits>
                </Fixed>
            </Variable>
        </DataItemFormat>
    </DataItem>

    <DataItem id="200">
        <DataItemName>Calculated Track Velocity in Polar Representation</DataItemName>
        <DataItemDefinition>Calculated track velocity expressed in Groundspeed and Heading.</DataItemDefinition>
        <DataItemFormat desc="Four-octet fixed length Data Item.">
            <Fixed length="4">
                <Bits from="32" to="17">
                    <BitsShortName>CGS</BitsShortName>
                    <BitsName>Calculated Groundspeed</BitsName>
                    <BitsUnit scale="0.2197265625">kt</BitsUnit> </Bits>
                <Bits from="16" to="1">
                    <BitsShortName>CHdg</BitsShortName>
                    <BitsName>Calculated Heading</BitsName>
                    <BitsUnit scale="0.0054931640625">deg</BitsUnit> </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="210">
        <DataItemName>Track Quality</DataItemName>
        <DataItemDefinition>Track quality in the form of a vector of standard deviations.</DataItemDefinition>
        <DataItemFormat desc="Four-octet fixed length Data Item.">
            <Fixed length="4">
                <Bits from="32" to="25">
                    <BitsShortName>SigmaX</BitsShortName>
                    <BitsUnit scale="0.0078125">NM</BitsUnit> </Bits>
                <Bits from="24" to="17">
                    <BitsShortName>SigmaY</BitsShortName>
                    <BitsUnit scale="0.0078125">NM</BitsUnit> </Bits>
                <Bits from="16" to="9">
                    <BitsShortName>SigmaV</BitsShortName>
                    <BitsUnit scale="0.2197265625">kt</BitsUnit> </Bits>
                <Bits from="8" to="1">
                    <BitsShortName>SigmaH</BitsShortName>
                    <BitsUnit scale="0.087890625">deg</BitsUnit> </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="220">
        <DataItemName>Aircraft Address</DataItemName>
        <DataItemDefinition>24-bits Mode S address assigned uniquely to each aircraft.</DataItemDefinition>
        <DataItemFormat>
            <Fixed length="3">
                <Bits from="24" to="1" encode="hex">
                    <BitsShortName>ACAddr</BitsShortName>
                    <BitsName>Aircraft Mode S Address</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="230">
        <DataItemName>Communications / ACAS Capability and Flight Status</DataItemName>
        <DataItemDefinition>Communications capability, airborne ACAS capability and flight status.</DataItemDefinition>
        <DataItemFormat desc="Two-octet fixed length Data Item.">
            <Fixed length="2">
                <Bits from="16" to="14">
                    <BitsShortName>COM</BitsShortName>
                    <BitsValue val="0">No communications capability (surveillance only)</BitsValue>
                    <BitsValue val="1">Comm. A and Comm. B capability</BitsValue>
                    <BitsValue val="2">Comm. A, Comm. B and Uplink ELM</BitsValue>
                    <BitsValue val="3">Comm. A, Comm. B, Uplink ELM and Downlink ELM</BitsValue>
                    <BitsValue val="4">Level 5 Transponder capability</BitsValue>
                </Bits>
                <Bits from="13" to="11">
                    <BitsShortName>STAT</BitsShortName>
                    <BitsValue val="0">No alert, no SPI, aircraft airborne</BitsValue>
                    <BitsValue val="1">No alert, no SPI, aircraft on ground</BitsValue>
                    <BitsValue val="2">Alert, no SPI, aircraft airborne</BitsValue>
                    <BitsValue val="3">Alert, no SPI, aircraft on ground</BitsValue>
                    <BitsValue val="4">Alert, SPI, aircraft airborne or on ground</BitsValue>
                    <BitsValue val="5">No alert, SPI, aircraft airborne or on ground</BitsValue>
                    <BitsValue val="7">Unknown</BitsValue>
                </Bits>
                <Bits bit="10">
                    <BitsShortName>SI</BitsShortName>
                    <BitsValue val="0">SI-Code Capable</BitsValue>
                    <BitsValue val="1">II-Code Capable</BitsValue>
                </Bits>
                <Bits bit="9">
                    <BitsShortName>spare</BitsShortName>
                    <BitsConst>0</BitsConst>
                </Bits>
                <Bits bit="8">
                    <BitsShortName>MSSC</BitsShortName>
                    <BitsValue val="0">No Mode-S Specific Service Capability</BitsValue>
                    <BitsValue val="1">Yes</BitsValue>
                </Bits>
                <Bits bit="7">
                    <BitsShortName>ARC</BitsShortName>
                    <BitsValue val="0">100 ft resolution</BitsValue>
                    <BitsValue val="1">25 ft resolution</BitsValue>
                </Bits>
                <Bits bit="6">
                    <BitsShortName>AIC</BitsShortName>
                    <BitsValue val="0">No Aircraft identification capability</BitsValue>
                    <BitsValue val="1">Yes</BitsValue>
                </Bits>
                <Bits bit="5">
                    <BitsShortName>B1A</BitsShortName>
                    <BitsName>BDS 1,0 bit 16</BitsName>
                </Bits>
                <Bits from="4" to="1">
                    <BitsShortName>B1B</BitsShortName>
                    <BitsName>BDS 1,0 bits 37/40</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="240">
        <DataItemName>Aircraft Identification</DataItemName>
        <DataItemDefinition>Target identification in 8 characters (6-bits characters encoding).</DataItemDefinition>
        <DataItemFormat desc="Six-octet fixed length Data Item.">
            <Fixed length="6">
                <Bits from="48" to="1" encode="6bitschar">
                    <BitsShortName>TId</BitsShortName>
                    <BitsName>Aircraft Identification / Callsign</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="250">
        <DataItemName>Mode S MB Data</DataItemName>
        <DataItemDefinition>BDS Register Data as extracted from the aircraft transponder.</DataItemDefinition>
        <DataItemFormat desc="Repetitive Data Item structure starting with an 8-bit Repetition Factor.">
            <Repetitive>
                <Fixed length="8">
                    <Bits from="64" to="9" encode="hex">
                        <BitsShortName>BDSDATA</BitsShortName>
                        <BitsName>56-bit message conveying BDS Register Data</BitsName>
                    </Bits>
                    <Bits from="8" to="5" encode="hex">
                        <BitsShortName>BDS1</BitsShortName>
                        <BitsName>BDS Register Address 1</BitsName>
                    </Bits>
                    <Bits from="4" to="1" encode="hex">
                        <BitsShortName>BDS2</BitsShortName>
                        <BitsName>BDS Register Address 2</BitsName>
                    </Bits>
                </Fixed>
            </Repetitive>
        </DataItemFormat>
    </DataItem>

    <DataItem id="260">
        <DataItemName>ACAS Resolution Advisory Report</DataItemName>
        <DataItemDefinition>Currently active Resolution Advisory (RA) generated by ACAS.</DataItemDefinition>
        <DataItemFormat desc="Seven-octet fixed length Data Item.">
            <Fixed length="7">
                <Bits from="56" to="1" encode="hex">
                    <BitsShortName>ACASRA</BitsShortName>
                    <BitsName>ACAS Resolution Advisory Data block</BitsName>
                </Bits>
            </Fixed>
        </DataItemFormat>
    </DataItem>

    <DataItem id="SP">
        <DataItemName>Special Purpose Field</DataItemName>
        <DataItemDefinition>Special Purpose Field definition placeholder.</DataItemDefinition>
        <DataItemFormat desc="Explicit variable structure.">
            <Explicit>
                <Fixed length="1">
                    <Bits from="8" to="1">
                        <BitsShortName>SP_VAL</BitsShortName>
                    </Bits>
                </Fixed>
            </Explicit>
        </DataItemFormat>
    </DataItem>

